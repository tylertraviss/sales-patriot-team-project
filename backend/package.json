{
  "name": "dla-awards-backend",
  "version": "1.0.0",
  "description": "DLA Awards data API — Express + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:init": "psql $DATABASE_URL -f src/db/schema.sql",
    "db:import": "node src/db/scripts/importAwardsCsv.js",
    "db:refresh-analytics": "node src/db/scripts/refreshAnalyticsCaches.js",
    "db:backfill-opportunity-fields": "node src/db/scripts/backfillOpportunityFields.js",
    "db:audit-opportunity-coverage": "node src/db/scripts/auditOpportunityCoverage.js",
    "db:test-opportunity-mappings": "node src/db/scripts/testOpportunityMappings.js",
    "smoke:opportunities": "node src/scripts/smokeOpportunities.js",
    "db:studio": "drizzle-kit studio --config=drizzle.config.mjs",
    "db:pull": "drizzle-kit pull --config=drizzle.config.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
