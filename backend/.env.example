# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dla_awards
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20

# Convenience URL (used by db:init npm script)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dla_awards
